{
	"name": "pi-cron",
	"version": "0.2.0",
	"description": "Schedule prompts to fire on a wall-clock interval. Each cron task is a separate, persistent pi conversation - main session stays untouched. Two deployment modes: extension (in-pi) for laptops, runner CLI + systemd for headless VMs.",
	"type": "module",
	"keywords": [
		"pi",
		"pi-coding-agent",
		"extension",
		"cron",
		"scheduler",
		"llm",
		"systemd",
		"agent"
	],
	"license": "MIT",
	"author": "Subsphere",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Subsphere/pi-cron.git"
	},
	"bugs": {
		"url": "https://github.com/Subsphere/pi-cron/issues"
	},
	"homepage": "https://github.com/Subsphere/pi-cron#readme",
	"pi": {
		"extensions": [
			"./cron.ts"
		]
	},
	"bin": {
		"pi-cron-runner": "./bin/pi-cron-runner.mjs"
	},
	"files": [
		"cron.ts",
		"bin",
		"README.md",
		"LICENSE",
		"examples"
	],
	"scripts": {
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"engines": {
		"node": ">=22"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "^0.70.0"
	},
	"devDependencies": {
		"@mariozechner/pi-coding-agent": "^0.70.2",
		"@types/node": "^22.10.5",
		"typescript": "^5.7.0",
		"vitest": "^3.2.4"
	}
}
